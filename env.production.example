# Copy this file to .env.production on the server (do NOT commit .env.production)

# Postgres (local container)
POSTGRES_USER=drwelnes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=drwelnes

# Prisma/NextAuth
DATABASE_URL=postgresql://drwelnes:CHANGE_ME_STRONG_PASSWORD@db:5432/drwelnes?schema=public
NEXTAUTH_URL=https://drwelnes.ru
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# GitHub CMS (optional, for admin publish/auth)
GITHUB_CMS_CLIENT_ID=CHANGE_ME_CLIENT_ID
GITHUB_CMS_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# Optional
# NODE_ENV=production
